/**
 * FIRESTORE SECURITY RULES - PRODUCTION HARDENED v1.0
 * Implements Strict Role-Based Access Control (RBAC) and Schema Validation.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isOwnerOfSalon(salonId) {
      return isAuthenticated() && get(/databases/$(database)/documents/salons/$(salonId)).data.ownerId == request.auth.uid;
    }

    // --- COLLECTIONS ---

    // USERS
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Users can only update their own profile, and cannot change their own role.
      allow update: if isAuthenticated() && (request.auth.uid == userId) && 
                    (request.resource.data.role == resource.data.role || hasRole('admin'));
      allow create: if isAuthenticated() && (request.auth.uid == userId);
      allow delete: if hasRole('admin');
    }

    // SALONS
    match /salons/{salonId} {
      allow read: if true;
      
      // Salon Creation: Authenticated users can create if they set themselves as owner.
      // In production, you might restrict this to users with 'owner' role.
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      
      // Salon Update: Only the owner or an admin can update.
      // Exception: Anyone can increment queueLength (Join Queue feature).
      allow update: if 
        hasRole('admin') || 
        (isAuthenticated() && resource.data.ownerId == request.auth.uid) ||
        (
          isAuthenticated() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['queueLength']) &&
          request.resource.data.queueLength == resource.data.queueLength + 1
        );
        
      allow delete: if hasRole('admin');
    }

    // BOOKINGS
    match /bookings/{bookingId} {
      allow read: if 
        hasRole('admin') || 
        (isAuthenticated() && resource.data.customerId == request.auth.uid) ||
        (isAuthenticated() && isOwnerOfSalon(resource.data.salonId));

      allow create: if 
        isAuthenticated() && 
        request.resource.data.customerId == request.auth.uid &&
        (
          (request.resource.data.paymentStatus == 'partial_paid' && request.resource.data.razorpayPaymentId != "") ||
          (request.resource.data.paymentStatus == 'success' && request.resource.data.razorpaySignature != "")
        );

      allow update: if 
        hasRole('admin') || 
        // Customers can ONLY cancel their own bookings or add UPI proof
        (
          isAuthenticated() && 
          resource.data.customerId == request.auth.uid &&
          (
            (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'bookingStatus']) && request.resource.data.bookingStatus == 'cancelled') ||
            (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upiTransactionId', 'upiScreenshotUrl']))
          )
        ) ||
        // Owners can update status AND verify payments
        (
          isAuthenticated() && 
          isOwnerOfSalon(resource.data.salonId) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['customerId', 'advanceAmount'])
        );

      allow delete: if hasRole('admin');
    }

    // NOTIFICATION LOGS
    match /notificationLogs/{logId} {
      allow read: if hasRole('admin') || 
                    (isAuthenticated() && resource.data.recipient == request.auth.uid);
      allow create: if isAuthenticated(); // Allow system-triggered logs via frontend
      allow update, delete: if hasRole('admin');
    }
    
    // REVIEWS
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if hasRole('admin') || (isAuthenticated() && resource.data.authorId == request.auth.uid);
    }

    // OWNER REQUESTS (Onboarding flow)
    match /ownerRequests/{reqId} {
      allow read: if hasRole('admin') || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if hasRole('admin');
    }

    // ADMIN LOGS
    match /adminLogs/{docId} {
      allow read: if hasRole('admin');
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
    
    // ANALYTICS
    match /analytics/{docId} {
      allow read, write: if hasRole('admin');
    }
  }
}
